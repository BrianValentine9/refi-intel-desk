# Normalize line endings: store text as LF in the repo, check out native.
* text=auto eol=lf

# Explicit text types.
*.py    text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf

# Binary — never normalize.
*.db    binary
*.sqlite binary
*.png   binary
*.jpg   binary
